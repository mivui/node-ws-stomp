{
  "name": "ws-stomp",
  "version": "2.0.4",
  "description": "stomp websocket library for node.js",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "deprecated": "",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js"
  },
  "peerDependencies": {
    "@nestjs/websockets": "^11.1.16"
  },
  "peerDependenciesMeta": {
    "@nestjs/websockets": {
      "optional": true
    }
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/websockets": "^11.1.16",
    "@rollup/plugin-commonjs": "^29.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.1",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint-standard": "^10.0.1",
    "vitest": "^4.0.18"
  },
  "author": "mivui",
  "license": "MIT",
  "keywords": [
    "stomp",
    "ws",
    "node",
    "websocket",
    "nest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivui/node-ws-stomp.git"
  },
  "bugs": {
    "url": "https://github.com/mivui/node-ws-stomp/issues"
  },
  "homepage": "https://github.com/mivui/node-ws-stomp#readme"
}
